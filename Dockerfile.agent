FROM golang:1.26 AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
# Build statically linked binary
RUN CGO_ENABLED=0 GOOS=linux GOARCH=arm64 go build -a -o pii-shield ./cmd/cleaner/main.go

FROM gcr.io/distroless/static:nonroot
WORKDIR /
COPY --from=builder /app/pii-shield .
USER 65532:65532

ENTRYPOINT ["/pii-shield"]
